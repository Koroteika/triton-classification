{
  "uid": "triton-image-classifier",
  "title": "Triton Image Classifier",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests per Second",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(nv_inference_request_success{model=\"image_classifier\"}[$__rate_interval])",
          "legendFormat": "success"
        },
        {
          "expr": "rate(nv_inference_request_failure{model=\"image_classifier\"}[$__rate_interval])",
          "legendFormat": "failure"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Average Request Duration, us",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(nv_inference_request_duration_us{model=\"image_classifier\"}[$__rate_interval]) / rate(nv_inference_request_success{model=\"image_classifier\"}[$__rate_interval])",
          "legendFormat": "avg duration"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Average Queue Time, us",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(nv_inference_queue_duration_us{model=\"image_classifier\"}[$__rate_interval]) / rate(nv_inference_request_success{model=\"image_classifier\"}[$__rate_interval])",
          "legendFormat": "queue time"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pending Requests",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "nv_inference_pending_request_count{model=\"image_classifier\"}",
          "legendFormat": "pending"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Requests",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "nv_inference_request_success{model=\"image_classifier\"}",
          "legendFormat": "success"
        },
        {
          "expr": "nv_inference_request_failure{model=\"image_classifier\"}",
          "legendFormat": "failure"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 16
      }
    }
  ]
}
